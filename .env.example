# Copy to .env and fill in real values. Never commit .env.
#
# NOTE: config.py accepts either naming convention below for Neo4j/Qdrant — use
# whichever your provisioning already gave you.

# --- DeepSeek (Stage 1: entity/relation extraction only) ---
DEEPSEEK_API_KEY=sk-your-deepseek-key

# --- Gemini API key (Stages 5 & 7: all answer generation, free tier) ---
# Also authenticates Gemma models served via the same API — see GEMINI_MODEL below.
GEMINI_API_KEY=your-gemini-key

# --- Neo4j Aura (graph store) ---
# Connection URI looks like: neo4j+s://<db-id>.databases.neo4j.io
NEO4J_URI=neo4j+s://your-db-id.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password
# Alternate names also accepted: NEO4J_AURA_URI, NEO4J_AURA_USER, NEO4J_AURA_PASSWORD

# --- Qdrant Cloud (vector store) ---
QDRANT_URL=https://your-cluster.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-key
# Alternate name also accepted: QDRANT_CLUSTER_ENDPOINT

# --- Optional tunables (defaults shown; override only if needed) ---
# DEEPSEEK_MODEL=deepseek-v4-flash
# GENERATION_BACKEND=deepseek
# ^ "deepseek": pay-per-use, no daily request cap (used by the live /query API and the
#   full eval run — see deepseek_common.py). "gemini": the original free-tier path,
#   still fully implemented, just not the default. See GEMINI_MODEL/RPM/RPD below if
#   switching back.
# DEEPSEEK_GENERATION_COST_CEILING_USD=1.5
# ^ Shared with DEEPSEEK_COST_CEILING_USD's account balance — both draw from the same
#   DeepSeek credit, so size this with that already-spent cost in mind.
# GEMINI_MODEL=gemma-4-31b-it
# ^ Only used when GENERATION_BACKEND=gemini. gemini-2.5-flash's real free-tier quota
#   measured only 20 requests/day for this project (vs. the 250-1500/day docs suggest)
#   — a Gemma model via this same API/key sits on a separate, empirically much more
#   generous quota bucket. Re-confirm live in AI Studio before relying on either number;
#   DailyQuotaTracker is keyed per-model, so switching models won't inherit a stale count.
# EMBED_MODEL=BAAI/bge-small-en-v1.5
# DEEPSEEK_COST_CEILING_USD=2.0
# EXTRACTION_CONCURRENCY=8
# GEMINI_RPM=15
# GEMINI_RPD=200
# ^ Only used when GENERATION_BACKEND=gemini. Informed estimates, not a confirmed
#   ceiling — the eval runner halts gracefully on a real 429 regardless of what's set
#   here, so erring high just risks a wasted retry cycle, not a crash.
# HOP_DEPTH=2
# TOP_K_VECTOR=5
# TOP_K_FINAL=8
# MAX_SEED_ENTITY_DEGREE=30
# ^ Excludes generic "hub" entities (a bare year, a nationality adjective) from graph
#   traversal — found live at full corpus scale, where a couple of high-degree seeds
#   stalled a single question's retrieval for minutes. See GraphRetriever's docstring.
# ALLOWED_ORIGINS=http://localhost:3000
# ^ Comma-separated. Only matters for direct browser calls to the API (e.g. /docs) —
#   the chat frontend talks to it via a server-side proxy, which isn't subject to CORS.
#   Add the deployed frontend's URL here once it exists (e.g. https://your-app.vercel.app).
